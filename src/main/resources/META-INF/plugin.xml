<idea-plugin>
    <id>com.github.cursorterm.cursor-cli-terminal</id>
    <name>Cursor CLI Terminal</name>
    <version>3.0.2</version>
    <vendor>cursorterm</vendor>

    <description><![CDATA[
    cursor-agent 工具窗：开启会话、注入 @ 路径、图片粘贴。不拦截 Enter，不修改终端滚动与输入行为。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="com.github.cursorterm.agent"
            anchor="bottom"
            factoryClass="com.github.cursorterm.CursorTerminalToolWindowFactory"
            icon="/icons/cursor.svg" />
    </extensions>
</idea-plugin>
