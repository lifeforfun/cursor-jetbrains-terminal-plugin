<idea-plugin>
    <id>com.github.cursorterm.cursor-cli-terminal</id>
    <name>Cursor CLI Terminal</name>
    <version>1.8.40</version>
    <vendor>cursorterm</vendor>

    <description><![CDATA[
    Embeds cursor-agent in a JetBrains IDE tool window. Supports session resume,
    Enter-to-append @file references from the active editor tab, and JediTerm scroll fixes.
    Compatible with IntelliJ Platform 2023.3+ (build 233).
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="com.github.cursorterm.EditorContextStartupActivity" />
        <toolWindow id="com.github.cursorterm.agent"
            anchor="bottom"
            factoryClass="com.github.cursorterm.CursorTerminalToolWindowFactory"
            icon="/icons/cursor.svg" />
    </extensions>
</idea-plugin>